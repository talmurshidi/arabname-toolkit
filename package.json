{
  "name": "arabname-toolkit",
  "version": "0.2.0",
  "private": true,
  "description": "Client-side Arabic names transliteration toolkit for academic researchers",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint": "oxlint --deny-warnings src tests scripts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:tree": "tsx scripts/generate-project-tree.ts",
    "docs:tree:check": "tsx scripts/generate-project-tree.ts --check",
    "find-degraded": "tsx scripts/find-degraded-transliterations.ts",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run docs:tree:check && npm run build",
    "release:patch": "tsx scripts/release.ts patch",
    "release:minor": "tsx scripts/release.ts minor",
    "release:major": "tsx scripts/release.ts major"
  },
  "dependencies": {
    "papaparse": "^5.4.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "lucide-react": "^0.546.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^24.0.0",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.0",
    "oxlint": "^1.0.0",
    "prettier": "^3.5.0",
    "tailwindcss": "^4.1.14",
    "ts-morph": "^25.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=22"
  }
}
